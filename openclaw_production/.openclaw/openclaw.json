{
  "meta": {
    "lastTouchedVersion": "2026.3.13",
    "lastTouchedAt": "2026-03-21T10:00:00.000Z"
  },
  "logging": {
    "level": "info"
  },
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "http://openclaw-ollama:11434",
        "apiKey": "ollama-local",
        "api": "ollama",
        "models": [
          {
            "id": "llama3.2:latest",
            "name": "llama3.2",
            "contextWindow": 16000,
            "maxTokens": 4096
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "ollama/llama3.2:latest"
      },
      "workspace": "/root/workspace",
      "memorySearch": {
        "enabled": false
      }
    },
    "list": [
      {
        "id": "asistente",
        "name": "JeiAssistant",
        "type": "support",
        "enabled": true,
        "model": "ollama/llama3.2:latest",
        "systemPrompt": "Eres JeiAssistant. Ayuda al Arquitecto a gestionar su infraestructura AI.",
        "skills": [
          "web-search"
        ]
      },
      {
        "id": "frontend-dev",
        "name": "Frontend Dev",
        "type": "coding",
        "enabled": true,
        "model": "ollama/llama3.2:latest",
        "systemPrompt": "Eres un experto en React y Tailwind. Tu misión es crear interfaces cyberpunk.",
        "skills": [
          "code-execution",
          "file-operations"
        ]
      }
    ]
  },
  "bindings": [
    {
      "agentId": "asistente",
      "match": {
        "channel": "telegram",
        "accountId": "*"
      }
    },
    {
      "agentId": "frontend-dev",
      "match": {
        "channel": "webchat",
        "accountId": "*"
      }
    }
  ],
  "gateway": {
    "port": 5000,
    "mode": "local",
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": {
        "source": "env",
        "provider": "default",
        "id": "OPENCLAW_GATEWAY_TOKEN"
      }
    },
    "controlUi": {
      "allowedOrigins": [
        "*"
      ]
    }
  },
  "channels": {
    "webchat": {
      "enabled": true
    },
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "allowFrom": [
        8503241862
      ],
      "groupPolicy": "open",
      "streaming": "partial"
    }
  }
}