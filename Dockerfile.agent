FROM node:22-slim

# 1. Configuración de Variables de Entorno
ENV OPENCLAW_HOME=/root/.openclaw
ENV NODE_ENV=production
ENV PYTHONUNBUFFERED=1

WORKDIR /app

# 2. Instalar dependencias del sistema (Kit completo para Skills y Compilación)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    lsof \
    bash \
    git \
    python3 \
    python3-pip \
    python3-venv \
    sqlite3 \
    make \
    g++ \
    cmake \
    build-essential \
    openssl \
    ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# 3. Instalar OpenClaw globalmente
# Usamos --unsafe-perm si es necesario para scripts de post-instalación de npm
RUN npm install -g openclaw@latest --ignore-scripts

# 4. Crear estructura de directorios siguiendo el estándar de OpenClaw
RUN mkdir -p $OPENCLAW_HOME/agents/main/sessions \
    $OPENCLAW_HOME/skills \
    $OPENCLAW_HOME/data \
    $OPENCLAW_HOME/cache \
    $OPENCLAW_HOME/credentials

# 5. Copiar archivos de configuración desde tu host
# Nota: Asegúrate de que estas rutas existan en tu carpeta de proyecto local
COPY openclaw.json $OPENCLAW_HOME/openclaw.json
COPY openClawSettings/agents.json $OPENCLAW_HOME/agents/agents.json
COPY openClawSettings/skills.json $OPENCLAW_HOME/skills/skills.json

# (Opcional) Copiar tus Skills personalizadas si ya las tienes
# COPY skills/ $OPENCLAW_HOME/skills/

# 6. Script de Inicialización Robusto
RUN printf '#!/bin/bash\n\
    set -e\n\
    echo "🤖 Iniciando OpenClaw Expert Mode..."\n\
    \n\
    # Ajustar permisos de seguridad para evitar WARNs de gateway\n\
    chmod 700 $OPENCLAW_HOME\n\
    find $OPENCLAW_HOME -type f -name "*.json" -exec chmod 600 {} +\n\
    \n\
    echo "📂 Cargando configuración desde: $OPENCLAW_HOME"\n\
    \n\
    # Limpieza preventiva de sesiones si el archivo existe\n\
    if [ -f "$OPENCLAW_HOME/agents/main/sessions/sessions.json" ]; then\n\
    echo "🧹 Limpiando sesiones antiguas..."\n\
    openclaw sessions cleanup --store "$OPENCLAW_HOME/agents/main/sessions/sessions.json" --enforce --fix-missing 2>/dev/null || true\n\
    fi\n\
    \n\
    echo "✅ Entorno listo. Ejecutando Gateway en puerto 5000..."\n\
    exec openclaw gateway run\n' > /app/entrypoint.sh && chmod +x /app/entrypoint.sh

# 7. Healthcheck para monitorear el estado del agente
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:5000/health 2>/dev/null || exit 1

# Puertos: 5000 (Gateway/UI), 8000/8001 (Webhooks/Dev)
EXPOSE 5000 8000 8001

ENTRYPOINT ["/app/entrypoint.sh"]