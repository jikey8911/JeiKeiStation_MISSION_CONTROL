FROM node:22-alpine

WORKDIR /app

# Instalar dependencias necesarias
RUN apk add --no-cache \
    curl \
    bash \
    git \
    python3 \
    make \
    g++ \
    openssl \
    ca-certificates

# Instalar OpenClaw globalmente (Saltando compilación C++ pesada de node-llama-cpp)
ENV NODE_PREGYP_BUILD_FROM_SOURCE=false
ENV GITHUB_ACTIONS=true
RUN npm install -g openclaw@latest

# Crear directorios necesarios
RUN mkdir -p /root/.openclaw/agents \
    /root/.openclaw/skills \
    /root/.openclaw/data \
    /root/.openclaw/cache

# Script de inicialización
RUN echo '#!/bin/bash\n\
    set -e\n\
    echo "Inicializando OpenClaw..."\n\
    \n\
    # Crear directorio de configuración si no existe\n\
    mkdir -p /root/.openclaw\n\
    \n\
    # Inicializar OpenClaw\n\
    openclaw setup --no-interactive 2>/dev/null || true\n\
    \n\
    echo "OpenClaw iniciado exitosamente"\n\
    echo "Ejecutando gateway..."\n\
    \n\
    # Ejecutar OpenClaw\n\
    exec openclaw\n\
    ' > /app/entrypoint.sh && chmod +x /app/entrypoint.sh

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:5000/health || exit 1

EXPOSE 5000 8000

ENV NODE_ENV=production

ENTRYPOINT ["/app/entrypoint.sh"]
