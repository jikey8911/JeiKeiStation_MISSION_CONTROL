# Usamos node:22-bookworm-slim
FROM node:22-bookworm-slim

# 1. Variables de Entorno
ENV OPENCLAW_HOME=/root
ENV NODE_ENV=production
ENV PYTHONUNBUFFERED=1
ENV PATH="/home/linuxbrew/.linuxbrew/bin:/home/linuxbrew/.linuxbrew/sbin:${PATH}:/usr/local/bin"

WORKDIR /app

# 2. Dependencias del Sistema
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl lsof bash git python3 python3-pip python3-venv \
    sqlite3 build-essential ca-certificates procps sudo && \
    rm -rf /var/lib/apt/lists/*

# 3. Instalación de OpenClaw (Global)
RUN npm install -g openclaw@latest

# 4. Preparación de directorios para Volúmenes
# Estos serán tus puntos de montaje en docker-compose
RUN mkdir -p ${OPENCLAW_HOME} /root/agents /root/skills /root/backups

# 5. Script de Inicialización Inteligente
# Este script verifica si existe configuración; si no, busca un backup.
RUN printf '#!/bin/bash\n\
    set -e\n\
    \n\
    echo "🤖 [OpenClaw] Verificando estado del Gateway..."\n\
    \n\
    # 1. Lógica de Restauración Opcional\n\
    if [ ! -f "${OPENCLAW_HOME}/openclaw.json" ]; then\n\
    echo "⚠️ No se encontró configuración en ${OPENCLAW_HOME}."\n\
    if [ -f "/root/backups/openclaw_backup.json" ]; then\n\
    echo "🔄 Restaurando desde backup encontrado..."\n\
    cp /root/backups/openclaw_backup.json ${OPENCLAW_HOME}/openclaw.json\n\
    else\n\
    echo "✨ Iniciando con configuración limpia (Primera ejecución)."\n\
    fi\n\
    fi\n\
    \n\
    # 2. Auto-reparación y Preflight\n\
    openclaw doctor --fix || true\n\
    \n\
    # 3. Ejecución en primer plano\n\
    echo "🚀 Iniciando Gateway de OpenClaw..."\n\
    exec openclaw gateway start --foreground --port 18789\n\
    ' > /app/entrypoint.sh && chmod +x /app/entrypoint.sh

# 6. Configuración de Red y Salud
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:18789/health || exit 1

EXPOSE 18789 8000 8001

ENTRYPOINT ["/app/entrypoint.sh"]