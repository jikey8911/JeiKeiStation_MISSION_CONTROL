# Dockerfile.agent
FROM python:3.10-slim

WORKDIR /app

# Instalar dependencias del sistema requeridas por GitPython u otras librerías
RUN apt-get update && apt-get install -y git && rm -rf /var/lib/apt/lists/*

# Copiar los requirements del agente si existen (asumiendo que los pusiste en agent_backend o la raíz)
# Si no tienes un requirements.txt global, instala las librerías base de OpenClaw manualmente
COPY server/agent_backend/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt
RUN pip install requests GitPython PyGithub colorama

# Copiar todo el repositorio para que el agente tenga contexto del código
COPY . .

# Comando por defecto: Ejecutar el heartbeat o el agente de monitoreo
# Puedes cambiar esto a cli_agent.py si quieres interactuar por consola
CMD ["python", "openclaw/skills/jeikei_mission_control/heartbeat.py"]