# Production Environment Configuration
# Copy this file to .env.production and fill in actual values

# Database
MYSQL_ROOT_PASSWORD=secure_root_password_change_this
MYSQL_USER=mission_user
MYSQL_PASSWORD=secure_db_password_change_this
MYSQL_DATABASE=mission_control

# API
NODE_ENV=production
PORT=3001

# API Keys and Secrets (populate with your actual values)
CLERK_SECRET_KEY=your_clerk_secret_key
GITHUB_TOKEN=your_github_token
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret

# Application URLs
VITE_API_URL=https://your-domain.com/api
JEIKEI_API_URL=https://your-domain.com/api/trpc

# Logging
LOG_LEVEL=info
