# ============================================================================
# JEIKEI STATION - PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================================================
# 
# IMPORTANTE: Este archivo es un EJEMPLO. 
# En producción, crear .env.production con valores reales.
# NUNCA commitear .env.production al repositorio.
#
# ============================================================================

# --- DATABASE (MySQL) ---
MYSQL_ROOT_PASSWORD=change_this_secure_password
MYSQL_USER=jeikei_user
MYSQL_PASSWORD=change_this_secure_password
MYSQL_DATABASE=jeikei_station
DATABASE_URL=mysql://jeikei_user:change_this_secure_password@mysql:3306/jeikei_station

# --- BACKEND (Node.js / tRPC) ---
PORT=3001
NODE_ENV=production
SERVICE_API_KEY=your_service_api_key_here
JWT_SECRET=your_jwt_secret_key_here

# --- REDIS (Cache & Session Store) ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- OPENCLAW INTEGRATION (IA Agent) ---
OPENCLAW_BASE_URL=http://openclaw-app:5000
OPENCLAW_API_KEY=your_openclaw_api_key_here
OPENCLAW_GATEWAY_TOKEN=your_openclaw_gateway_token_here
OPENCLAW_AUTH_TOKEN=your_openclaw_auth_token_here

# --- OLLAMA (LLM) ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# --- EXTERNAL API KEYS ---
# GitHub
GITHUB_TOKEN=your_github_token_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Google APIs
GOPLACES_API_KEY=your_goplaces_api_key_here
NANO_BANANA_API_KEY=your_nano_banana_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Notion
NOTION_API_KEY=your_notion_api_key_here

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Mistral
MISTRAL_API_KEY=your_mistral_api_key_here

# Voyage
VOYAGE_API_KEY=your_voyage_api_key_here

# --- AUTHENTICATION (Clerk) ---
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here

# --- FRONTEND (Vite / React) ---
VITE_API_URL=http://jeikei_api:3001
VITE_OAUTH_PORTAL_URL=http://openclaw-app:5000
VITE_APP_ID=jeikei_mission_control
VITE_OPENCLAW_GATEWAY_URL=/api/v1/ws
VITE_OPENCLAW_GATEWAY_TOKEN=your_openclaw_gateway_token_here

# --- FORGE / MAPS ---
VITE_FRONTEND_FORGE_API_URL=http://openclaw-app:5000
VITE_FRONTEND_FORGE_API_KEY=your_forge_api_key_here
BUILT_IN_FORGE_API_URL=http://openclaw-app:5000
BUILT_IN_FORGE_API_KEY=your_forge_api_key_here

# --- LOGGING ---
LOG_LEVEL=info

# --- DOMAIN CONFIGURATION ---
# Usar para SSL/TLS en producción
DOMAIN=your-domain.com
SSL_CERT_PATH=/etc/letsencrypt/live/your-domain.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/your-domain.com/privkey.pem
