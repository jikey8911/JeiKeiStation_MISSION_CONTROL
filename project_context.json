    ],
    "pending": [
      "Visualización de grafo de dependencias completo",
      "Tests unitarios completos para backend",
      "Documentación README.md final",
      "Configuración CI/CD",
      "Repositorio GitHub público/privado"
    ]
  },
  "file_structure": {
    "root": {
      "client/": "Frontend React + Vite",
      "server/": "Backend tRPC + Express",
      "drizzle/": "Esquema de base de datos y migraciones",
      "shared/": "Constantes y tipos compartidos",
      "openclaw/": "Integración con OpenClaw (skills, scripts Python)",
      "scripts/": "Scripts de utilidad",
      "patches/": "Parches para dependencias (pnpm)",
      ".github/": "Configuración de GitHub Actions",
      ".vscode/": "Configuración de VS Code",
      ".venv/": "Entorno virtual de Python"
    },
    "server": {
      "_core/": "Core del servidor (trpc, auth, env, systemRouter)",
      "agent_backend/": "Lógica de agentes AI",
      "db.ts": "Capa de acceso a datos (Drizzle ORM)",
      "db.test.ts": "Tests unitarios de db.ts",
      "routers.ts": "Routers tRPC principales",
      "serviceAuth.ts": "Middleware de autenticación por API Key",
      "webhooksRouter.ts": "Router para webhooks de notificaciones",
      "projectOwnerRouter.ts": "Router del Project Owner Agent",
      "notificationsRouter.ts": "Router de notificaciones",
      "utils.ts": "Utilidades (parseMarkdownTasks, findBestAgent, hasCyclicDependency)",
      "ee.ts": "EventEmitter para eventos del sistema"
    },
    "openclaw": {
      "skills/jeikei_mission_control/": {
        "SKILL.md": "Definición de la skill para OpenClaw",
        "jeikei_skill.py": "Cliente Python con lógica de matching",
        "heartbeat.py": "Script de monitoreo automático"
      }
    }
  },
