  },
  "api_examples": {
    "list_tasks": {
      "endpoint": "/api/trpc/tasks.list",
      "method": "GET",
      "auth": "x-api-key header (para serviceProcedure) o cookie Clerk (para protectedProcedure)",
      "params": {
        "sprintId": "optional - filtrar por sprint"
      },
      "response": "Array de objetos Task"
    },
    "auto_assign_task": {
      "endpoint": "/api/trpc/tasks.serviceAutoAssign",
      "method": "POST",
      "auth": "x-api-key header required",
      "body": {
        "taskId": "number"
      },
      "response": "{ agentId: number, agentName: string }"
    },
    "get_blocking_tasks": {
      "endpoint": "/api/trpc/dependencies.getBlocking",
      "method": "GET",
      "auth": "x-api-key header o cookie Clerk",
      "params": {
        "taskId": "number"
      },
      "response": "Array de objetos Task (tareas que bloquean)"
    },
    "register_webhook": {
      "endpoint": "/api/trpc/webhooks.register",
      "method": "POST",
      "auth": "x-api-key header",
      "body": {
        "url": "string",
        "eventTypes": "string[] - ['task_blocked', 'qa_completed', etc.]"
      },
      "response": "{ success: boolean, webhookId: string }"
    }
  },
  "notes": {
    "scrum_workflow": "Las tareas siguen el flujo: todo → in_progress → review → qa → done. No se permite saltar estados. Las tareas con dependencias no bloqueadas no pueden pasar a in_progress.",
    "agent_matching": "El matching de habilidades compara requiredSkills de la tarea con skills del agente. Se considera también currentWorkload vs maxCapacity. El agente con mayor score y disponibilidad es seleccionado.",
    "openclaw_heartbeat": "El script heartbeat.py se ejecuta cada 30 minutos, busca tareas huérfanas (sin assignedAgentId y status != 'done'), analiza matching de habilidades, y asigna automáticamente usando el serviceProcedure.",
    "notifications": "Las notificaciones se disparan automáticamente en transiciones de estado: task_blocked (cuando hay dependencias), qa_completed (cuando pasa a done), sprint_closed, task_assigned, approval_pending.",
    "docker_setup": "El backend corre en puerto 3001, frontend en 3000 con proxy a API. MySQL en 3306. El entrypoint.sh ejecuta db:push automáticamente al iniciar."
  }
}
