# =============================================================================
# JEIKEI STATION - MISSION CONTROL (.env.example)
# =============================================================================

# --- Backend (Node.js / tRPC) ---
# Nota: Dentro de Docker el host es 'mysql'. Si corres localmente usa 'localhost'.
DATABASE_URL=mysql://jeikei_user:jeikei_password@mysql:3306/jeikei_station
PORT=3000
SERVICE_API_KEY=jk_secret_agent_key_2026
JWT_SECRET=tu_secreto_aleatorio_aqui

# --- OpenClaw Integration (Agente IA) ---
# URL interna para que el backend hable con el agente (usando nombre de servicio docker)
OPENCLAW_BASE_URL=http://openclaw_agent:8000
OPENCLAW_API_KEY=jk_secret_agent_key_2026

# Token necesario para que el agente pueda hacer git push
GITHUB_TOKEN=tu_token_de_github_aqui

# URL interna para que el agente le hable a la API de Node (usando nombre de servicio docker)
JEIKEI_API_URL=http://jeikei_platform:3000/api/trpc

# --- Frontend (Vite / React) ---
# En Codespaces, usa la URL pública generada (ej. https://xxx-3000.app.github.dev/)
VITE_API_URL=https://tu-codespace-3000.app.github.dev/
VITE_OAUTH_PORTAL_URL=https://tu-codespace-3000.app.github.dev/
VITE_APP_ID=jeikei_mission_control

# --- Clerk Authentication ---
# Obtén estas claves en tu Dashboard de Clerk (https://clerk.com)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXX
CLERK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXX

# --- Configuración de Forge / Mapas ---
VITE_FRONTEND_FORGE_API_URL=https://api.forge.com/v1
VITE_FRONTEND_FORGE_API_KEY=tu_api_key_de_forge_frontend
BUILT_IN_FORGE_API_URL=https://api.forge.com/v1
BUILT_IN_FORGE_API_KEY=tu_api_key_de_forge_backend

# --- NOTA PARA CODESPACES ---
# 1. Asegúrate de que el puerto 3000 esté configurado como 'Público'
#    en la pestaña de Puertos de VS Code.
# 2. VITE_API_URL debe terminar en '/' para evitar problemas de concatenación.
