# =============================================================================
# JEIKEI STATION - MISSION CONTROL (.env.example)
# =============================================================================
# Copia este archivo a un nuevo archivo llamado '.env' y completa los valores.
# NO subas el archivo '.env' real al repositorio.

# -----------------------------------------------------------------------------
# 1. CONFIGURACIÓN DEL SERVIDOR Y BACKEND (Node.js / tRPC)
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# Secreto para la firma de cookies y JWT
JWT_SECRET=tu_secreto_aleatorio_aqui

# Conexión a la Base de Datos (MySQL)
# Formato: mysql://usuario:contraseña@host:puerto/nombre_db
# Si usas Docker, el host es 'mysql' (nombre del servicio en docker-compose)
DATABASE_URL=mysql://jeikei_user:jeikei_password@mysql:3306/jeikei_station

# URL del servidor de autenticación (si aplica)
OAUTH_SERVER_URL=https://tu-servidor-oauth.com

# ID del propietario para permisos especiales
OWNER_OPEN_ID=tu_openid_aqui

# -----------------------------------------------------------------------------
# 2. INTEGRACIÓN CON CLERK (Autenticación)
# -----------------------------------------------------------------------------
# Obtén estas claves en tu Dashboard de Clerk (https://clerk.com)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXX
CLERK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# 3. CONFIGURACIÓN DEL FRONTEND (Vite / React)
# -----------------------------------------------------------------------------
# URL base de la API para el cliente
VITE_API_URL=http://localhost:3000

# Identificador de la aplicación
VITE_APP_ID=jeikei_station_v1

# -----------------------------------------------------------------------------
# 4. CONFIGURACIÓN DE FORGE / MAPAS / IA
# -----------------------------------------------------------------------------
# Configuración para el backend
BUILT_IN_FORGE_API_URL=https://api.forge.com/v1
BUILT_IN_FORGE_API_KEY=tu_api_key_de_forge_backend

# Configuración para el frontend (accesible vía import.meta.env)
VITE_FRONTEND_FORGE_API_URL=https://api.forge.com/v1
VITE_FRONTEND_FORGE_API_KEY=tu_api_key_de_forge_frontend

# -----------------------------------------------------------------------------
# 5. INTEGRACIÓN CON GITHUB Y AGENTES (OpenClaw)
# -----------------------------------------------------------------------------
# Token de acceso personal de GitHub (requerido para operaciones de Git por el agente)
GITHUB_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Configuración de OpenClaw (Agente de IA)
SERVICE_API_KEY=jk_secret_agent_key_2026
OPENCLAW_BASE_URL=http://localhost:3000/api/trpc
OPENCLAW_API_KEY=jk_secret_agent_key_2026

# -----------------------------------------------------------------------------
# NOTA PARA CODESPACES:
# Si usas GitHub Codespaces, asegúrate de que los puertos 3000 y 5173 
# estén configurados como 'Públicos' en la pestaña de Puertos de VS Code.
# -----------------------------------------------------------------------------
